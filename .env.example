# Environment variables
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2

# Database (for production use PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/gbv_db
DB_CONN_MAX_AGE=600

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

# Upload limits
MAX_EVIDENCE_FILE_SIZE_MB=20

# Security
SECURE_SSL_REDIRECT=False
LOG_LEVEL=INFO

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Twilio (for SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
TWILIO_ENABLE_VOICE_CALLS=True

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json

# Real owner accounts that can receive AI escalations and emergency broadcasts
AI_OWNER_USERNAMES=admin,safety_owner_1,safety_owner_2

# Authority contacts used for emergency SMS fan-out (JSON array)
AUTHORITY_ALERT_CONTACTS=[{"name":"Central Police Station","phone_number":"+254700000100"},{"name":"County Gender Desk","phone_number":"+254700000101"},{"name":"Local Rescue Coordinator","phone_number":"+254700000102"}]

# Local/national GBV hotline number (for chatbot quick action)
GBV_HOTLINE_NUMBER=

# Email
DEFAULT_FROM_EMAIL=noreply@gbvapp.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
APP_REGISTER_URL=http://localhost:3000/register

# AI Gateway (optional; set for external AI API calls)
AI_PROVIDER=none
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=

# OpenAI
AI_OPENAI_API_BASE_URL=https://api.openai.com
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=
AI_PROVIDER_FAILOVER_ORDER=azure-openai,anthropic
AI_PROVIDER_429_MAX_RETRIES=2
AI_PROVIDER_429_BACKOFF_BASE_SECONDS=0.8
AI_PROVIDER_429_JITTER_SECONDS=0.6
AI_PROVIDER_429_COOLDOWN_SECONDS=300
AI_PROVIDER_SKIP_UNCONFIGURED=True

# Azure OpenAI
AI_AZURE_OPENAI_ENDPOINT=
AI_AZURE_OPENAI_API_KEY=
AI_AZURE_OPENAI_DEPLOYMENT=
AI_AZURE_OPENAI_API_VERSION=2024-10-21

# Anthropic
AI_ANTHROPIC_API_BASE_URL=https://api.anthropic.com
AI_ANTHROPIC_API_KEY=
AI_ANTHROPIC_MODEL=
AI_ANTHROPIC_VERSION=2023-06-01
